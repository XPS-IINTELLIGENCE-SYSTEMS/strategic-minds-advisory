# AI in Action Labs runtime
VITE_APP_MODE=production
VITE_DATA_MODE=supabase

# Supabase public browser env
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Groq serverless env
# Prefer server-only GROQ_API_KEY in Vercel. Do not expose private keys in frontend code.
GROQ_API_KEY=your-groq-server-key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional frontend-only visibility flag. Avoid putting private Groq keys in VITE_* unless intentionally public.
VITE_GROQ_MODEL=llama-3.3-70b-versatile
