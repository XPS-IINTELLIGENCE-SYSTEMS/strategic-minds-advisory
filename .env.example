# AI in Action Labs environment contract
# Do not commit real values. Put real values in Vercel Environment Variables and GitHub Actions Secrets.

# Runtime mode
VITE_APP_MODE=production
VITE_DATA_MODE=supabase
AI_AUTONOMY_MODE=controlled
AI_ALLOW_PUBLIC_PUBLISH=false
AI_REQUIRE_HUMAN_APPROVAL=true

# Supabase public browser reads
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Server-side Supabase writes
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI generation
GROQ_API_KEY=your-groq-server-key
GROQ_MODEL=llama-3.3-70b-versatile
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# Market data
# Finnhub is optional. If missing, ETF/equity prices are marked unavailable instead of fabricated.
FINNHUB_API_KEY=your-finnhub-key

# Cron protection
# Recommended for manual/API-triggered cron routes. Vercel Cron may call routes without this header.
CRON_SECRET=change-me

# Optional public base URL used by GitHub Actions failover workflows
AI_IN_ACTION_BASE_URL=https://strategicmindsadvisory.com

# Future media integrations
HEYGEN_API_KEY=your-heygen-key
HEYGEN_DEFAULT_AVATAR_ID=your-avatar-id
HEYGEN_DEFAULT_VOICE_ID=your-voice-id

# Future publishing integrations. Leave blank until human approval.
YOUTUBE_API_KEY=
TIKTOK_CLIENT_ID=
LINKEDIN_CLIENT_ID=
X_API_KEY=
